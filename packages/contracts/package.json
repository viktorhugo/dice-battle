{
  "name": "contracts",
  "version": "0.1.0",
  "description": "DiceBattle smart contract for Desafío COP",
  "license": "MIT",
  "private": true,
  "scripts": {
    "install-deps": "make install",
    "build": "forge build",
    "test": "forge test -vv",
    "test:fuzz": "forge test --match-test testFuzz -vvv",
    "test:gas": "forge test --gas-report",
    "coverage": "forge coverage --ir-minimum --report summary",
    "fmt": "forge fmt",
    "lint": "forge fmt --check",
    "clean": "forge clean && rm -rf cache out broadcast",
    "anvil": "anvil --fork-url https://forno.celo.org --chain-id 42220",
    "deploy:sepolia": "forge script script/Deploy.s.sol:Deploy --rpc-url celo_sepolia --account celo-sepolia --broadcast --verify -vvvv",
    "deploy:mainnet": "forge script script/Deploy.s.sol:Deploy --rpc-url celo --account celo-mainnet --broadcast --verify --slow -vvvv"
  }
}
