{
  "name": "dice-battle",
  "version": "0.1.0",
  "description": "PvP dice-rolling betting game built as a MiniApp for MiniPay on Celo",
  "author": "Victor Hugo Mosquera Alvarado (Cappy)",
  "license": "MIT",
  "private": true,
  "packageManager": "pnpm@9.12.0",
  "engines": {
    "node": ">=22.0.0",
    "pnpm": ">=9.0.0"
  },
  "scripts": {
    "build": "pnpm -r build",
    "build:contracts": "pnpm --filter contracts build",
    "build:web": "pnpm --filter web build",
    "test": "pnpm -r test",
    "test:contracts": "pnpm --filter contracts test",
    "test:web": "pnpm --filter web test",
    "dev": "pnpm --filter web dev",
    "lint": "pnpm -r lint",
    "fmt": "pnpm -r fmt",
    "clean": "pnpm -r clean && rm -rf node_modules",
    "sync-abi": "node scripts/sync-abi.mjs",
    "deploy:sepolia": "pnpm --filter contracts deploy:sepolia && pnpm sync-abi",
    "deploy:mainnet": "pnpm --filter contracts deploy:mainnet && pnpm sync-abi"
  },
  "devDependencies": {
    "@types/node": "^22.0.0",
    "prettier": "^3.3.3",
    "typescript": "^5.5.0"
  }
}
