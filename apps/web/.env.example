# Copy to .env.local and fill in

# Deployed DiceBattle contract address
NEXT_PUBLIC_GAME_ADDRESS=

# Network: "celo_sepolia" for dev/testnet, "celo" for production
# Tokens available per network:
#   celo_sepolia → cUSD, CELO
#   celo         → cUSD, USDT, USDC
NEXT_PUBLIC_NETWORK=celo_sepolia

# Optional: custom RPC endpoint (defaults to Forno)
# NEXT_PUBLIC_RPC_URL=https://forno.celo.org

# Reown (WalletConnect) project ID — get one at https://dashboard.reown.com
NEXT_PUBLIC_REOWN_PROJECT_ID=

# Block at which DiceBattle was deployed on Celo mainnet — used as fromBlock in
# getLogs. Only needed for NEXT_PUBLIC_NETWORK=celo (Sepolia uses a hardcoded value).
NEXT_PUBLIC_GAME_DEPLOY_BLOCK=
