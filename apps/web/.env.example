# Copy to .env.local and fill in

# Canonical public URL of the app — used for metadataBase (OG/Twitter tags).
# In Vercel this is NOT needed if using the default *.vercel.app domain;
# VERCEL_URL is injected automatically. Set this only for custom domains.
# Example: https://dice-battle-web.vercel.app
NEXT_PUBLIC_URL=

# Deployed DiceBattle contract address
NEXT_PUBLIC_GAME_ADDRESS=

# Deployed DailyTournament contract address (leave empty to hide tournament UI)
NEXT_PUBLIC_TOURNAMENT_ADDRESS=

# Network: "celo_sepolia" for dev/testnet, "celo" for production
# Tokens available per network:
#   celo_sepolia → cUSD, CELO
#   celo         → cUSD, USDT, USDC
NEXT_PUBLIC_NETWORK=celo_sepolia

# Optional: custom RPC endpoint (defaults to Forno)
# NEXT_PUBLIC_RPC_URL=https://forno.celo.org

# Reown (WalletConnect) project ID — get one at https://dashboard.reown.com
NEXT_PUBLIC_REOWN_PROJECT_ID=

# Block at which DiceBattle was deployed on Celo mainnet — used as fromBlock in
# getLogs. Only needed for NEXT_PUBLIC_NETWORK=celo (Sepolia uses a hardcoded value).
NEXT_PUBLIC_GAME_DEPLOY_BLOCK=

# Envio/Hasura indexer — public endpoint (no secret needed for read queries)
NEXT_PUBLIC_INDEXER_URL=

# Server-side only: Hasura admin secret for cron/API routes. NEVER use NEXT_PUBLIC_ prefix.
INDEXER_ADMIN_SECRET=

# Secret for Vercel Cron authentication. Generate with: openssl rand -base64 24
CRON_SECRET=

# Private key of the tournament owner wallet (for cron to call setTopWinners on-chain)
TOURNAMENT_OWNER_PRIVATE_KEY=
